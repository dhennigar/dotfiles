{
	"layer": "top",
	"position": "bottom",
	"height": 30,
	"spacing": 4,
	"modules-left": ["wlr/taskbar"],
	"modules-right": ["tray","pulseaudio","battery","clock"],

	"tray": {
		"icon-size": 21,
		"spacing": 10
	},
	"pulseaudio": {
		"format": "v: {volume}%"
	},

	"battery": {
		"format": "b: {capacity}%"
	},

	"wlr/taskbar": {
		"all-outputs": true,
		"format": "{app_id}",
		"tooltip": false,
		"on-click": "activate",
		"on-click-right": "minimize", 
		"on-click-middle": "fullscreen",
		"app_ids-mapping": {
			"firefox": "Firefox"
		}
	}
}
