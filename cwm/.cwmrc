# ~/.cwmrc

# turn off default keys
unbind-key all
unbind-mouse all

# appearance
borderwidth 2
color activeborder	"#ffffff"
color inactiveborder 	"#333333"
color font		"#000000"
color selfont		"#ffffff"
color menubg		"#ffffff"
color menufg		"#333333"
fontname		"xft:Roboto Mono:size=10"

# group commands
sticky yes
bind-key	4-1		group-only-1
bind-key	4-2		group-only-2
bind-key	4-3		group-only-3
bind-key	4-4		group-only-4
bind-key	4S-1		window-movetogroup-1
bind-key	4S-2		window-movetogroup-2
bind-key	4S-3		window-movetogroup-3
bind-key	4S-4		window-movetogroup-4
bind-key	4-0		window-stick

# application menu
command		qutebrowser	"qutebrowser"
command		ranger		"my-term -e ranger"
command		rstudio		"rstudio"

# reserved commands
command		term		"my-term"
command		lock		"slock"

# launch applications
bind-key	4-Return	terminal
bind-key	4-b		qutebrowser
bind-key	4S-space	menu-exec
bind-key	4-space		menu-cmd
bind-key	4-d		"print-date"
bind-key	4-t		"print-time"
bind-key	4-Escape	"dunstctl close"

# manage windows
moveamount	15
bind-key	4-h		window-move-left
bind-key	4-j		window-move-down
bind-key	4-k		window-move-up
bind-key	4-l		window-move-right
bind-key	4S-h		window-resize-left-big
bind-key	4S-j		window-resize-down-big
bind-key	4S-k		window-resize-up-big
bind-key	4S-l		window-resize-right-big
bind-key	4M-h		window-snap-left
bind-key	4M-j		window-snap-down
bind-key	4M-k		window-snap-up
bind-key	4M-l		window-snap-right
bind-key	M-Tab		window-cycle
bind-key	MS-Tab		window-rcycle
bind-key	4-n		window-cycle
bind-key	4-p		window-rcycle
bind-key	4S-q		window-close
bind-key	4-f		window-fullscreen
bind-key	4-m		window-maximize
bind-key	4S-t		window-vtile
bind-key	4-minus		window-vmaximize
bind-key	4-equal		window-hmaximize

# media keys
bind-key	XF86AudioRaiseVolume	"pamixer --increase 10"
bind-key	XF86AudioLowerVolume 	"pamixer --decrease 10"
bind-key	XF86AudioMute		"pamixer --toggle-mute"
bind-key	XF86MonBrightnessUp	"brightnessctl set +10%"
bind-key	XF86MonBrightnessDown	"brightnessctl set 10%-"

# window manager actions
bind-key 	4S-Escape	quit
bind-key 	4S-r		restart
bind-key	4S-Delete	lock

# mouse commands
bind-mouse	4-1		window-move
bind-mouse	4-3		window-resize
bind-mouse	4-2		window-maximize
bind-mouse	4S-2		window-minimize
