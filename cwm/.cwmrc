# ~/.cwmrc

# turn off default keys
unbind-key all
unbind-mouse all

# appearance
borderwidth 2

# group commands
sticky yes
bind-key	4-1		group-only-1
bind-key	4-2		group-only-2
bind-key	4-3		group-only-3
bind-key	4-4		group-only-4
bind-key	4S-1		window-movetogroup-1
bind-key	4S-2		window-movetogroup-2
bind-key	4S-3		window-movetogroup-3
bind-key	4S-4		window-movetogroup-4


# launch applications
bind-key	4-Return	"urxvt"
bind-key	4-b		"qutebrowser"
bind-key	4-space		menu-exec
bind-key	4S-space	menu-cmd
command		qutebrowser	qutebrowser
command		urxvt		urxvt
command		ranger		"urxvt -e ranger"

# manage windows
bind-key	4-h		window-move-left-big
bind-key	4-j		window-move-down-big
bind-key	4-k		window-move-up-big
bind-key	4-l		window-move-right-big
bind-key	4S-h		window-resize-left-big
bind-key	4S-j		window-resize-down-big
bind-key	4S-k		window-resize-up-big
bind-key	4S-l		window-resize-right-big
bind-key	4M-h		window-snap-left
bind-key	4M-j		window-snap-down
bind-key	4M-k		window-snap-up
bind-key	4M-l		window-snap-right
bind-key	M-Tab		window-cycle
bind-key	MS-Tab		window-rcycle
bind-key	4-q		window-close
bind-key	4-f		window-fullscreen
bind-key	4-m		window-maximize
bind-key	4-t		window-vtile

# window manager actions
bind-key 	4-Escape	quit
bind-key 	4S-r		restart

# mouse commands
bind-mouse	4-1		window-move
bind-mouse	4-3		window-resize
bind-mouse	4-2		window-maximize
bind-mouse	4S-2		window-minimize
